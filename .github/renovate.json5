{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "packageRules": [
    {
      "groupName": "all patch versions",
      "matchUpdateTypes": ["patch"],
      "schedule": ["before 8am every weekday"]
    },
    {
      "matchUpdateTypes": ["minor", "major"],
      "schedule": ["before 8am on Monday"]
    },
    {
      "matchDepNames": [
        "open-telemetry/semantic-conventions",
        "bidetofevil/semantic-conventions-end-user-client"
      ],
      "ignoreUnstable": false
    }
  ],
  // Tracks the semantic convention registry versions in gradle/libs.versions.toml
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["gradle/libs.versions.toml"],
      "matchStrings": ["semanticConventionsCore = \"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "open-telemetry/semantic-conventions",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["gradle/libs.versions.toml"],
      "matchStrings": ["semanticConventionsEndUserClient = \"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "bidetofevil/semantic-conventions-end-user-client",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "labels": [
    "dependencies"
  ]
}

{%- endif -%}
{%- set my_class_name = ctx.name | pascal_case ~ "Event" -%}

package {{ params.package }}.events

import io.opentelemetry.kotlin.ExperimentalApi
import io.opentelemetry.kotlin.attributes.AnyValue
import io.opentelemetry.kotlin.attributes.AttributesMutator
import io.opentelemetry.kotlin.logging.Logger
import io.opentelemetry.kotlin.semconv.IncubatingApi
{%- if params.package != "io.opentelemetry.kotlin.semconv" %}
import io.opentelemetry.kotlin.semconv.events.OpenTelemetryEvent
{%- endif %}

// Autogenerated OpenTelemetry semantic convention event for '{{ctx.name}}'.
//
// DO NOT EDIT - AUTOGENERATED FILE
{{ [ctx.brief, concat_if("\n\nNotes:\n\n", ctx.note)] | comment }}
@ExperimentalApi
{%- if ctx.stability != "stable" %}
@IncubatingApi
{%- endif %}
{%- if ctx is deprecated %}
@Deprecated("{{ ctx.deprecated.note | replace('\n', ' ') | trim  }}")
{%- endif %}
class {{ my_class_name }}(
  {%- for attribute in ctx.attributes | rejectattr("name", "in", ctx.excluded_attributes) %}
    {%- set required = attribute.requirement_level == "required" %}
    {{ [attribute.brief, concat_if("\n\nNotes:\n\n", attribute.note)] | comment | indent(4) }}
    val {{ attribute.name | camel_case }}: {% if attribute.type == "any" %}AnyValue{% else %}{{ attribute.type | instantiated_type | map_text("kotlin_event_type") }}{% endif %}{{ '?' if not required else '' }}{{ ' = null' if not required else '' }},
  {%- endfor %}
) : OpenTelemetryEvent {

    override fun emit(
        logger: Logger,
        attributes: (AttributesMutator.() -> Unit)?,
    ) {
        logger.emit(
            eventName = "{{ ctx.name }}",
        ) {
          {%- for attribute in ctx.attributes | rejectattr("name", "in", ctx.excluded_attributes) %}
            {%- set required = attribute.requirement_level == "required" %}
            {%- if attribute.type == "any" -%}
              {%- set setter = "setAnyValueAttribute" -%}
            {%- else -%}
              {%- set setter = attribute.type | instantiated_type | map_text("kotlin_event_attribute_setter") -%}
            {%- endif %}
            {%- if required %}
            {{ setter }}("{{ attribute.name }}", {{ attribute.name | camel_case }})
            {%- else %}
            {{ attribute.name | camel_case }}?.let { {{ setter }}("{{ attribute.name }}", it) }
            {%- endif %}
          {%- endfor %}
            attributes?.invoke(this)
        }
    }
}
